# Database
DATABASE_URL=sqlite:///./jarvis.db
# For PostgreSQL (Docker):
# DATABASE_URL=postgresql://jarvis:jarvis_secret@db:5432/jarvis_os

# JWT Authentication
JWT_SECRET=change-me-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=30

# AI Assistant (optional)
OPENAI_API_KEY=

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# PostgreSQL (Docker)
POSTGRES_USER=jarvis
POSTGRES_PASSWORD=jarvis_secret
POSTGRES_DB=jarvis_os
