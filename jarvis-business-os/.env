# ══════════════════════════════════════════════════
# JARVIS BUSINESS OS — Configuration
# ══════════════════════════════════════════════════

# Mistral API (REQUIRED — get your key at https://console.mistral.ai)
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-small-latest

# Local LLM fallback (optional — requires Ollama running)
USE_LOCAL_LLM=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Voice
WHISPER_MODEL=base
TTS_VOICE=fr-FR-HenriNeural
